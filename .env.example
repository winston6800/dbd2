# Supabase (public - safe to expose in frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (public - safe to expose in frontend, not used yet but reserved)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe (secret - server/Vercel functions only, never expose to frontend)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...   # The $20/month recurring price ID from your Stripe dashboard

# Supabase (secret - server/Vercel functions only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used for Stripe redirect URLs)
APP_URL=https://your-app.vercel.app
